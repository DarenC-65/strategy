<script>
(function(){
  "use strict";

  var PHASES = {
    Orient: {q:[0,1,2], read:"You're setting strategy against a landscape you haven't mapped. Build a clear, specific point of view on how AI moves value in your industry before spending on tools."},
    Assess: {q:[3,4,5], read:"You may be chasing prizes you can't defend or capture. Fix the foundation first — pin down which proprietary asset gives you a right to win, and whether you can actually execute."},
    Commit: {q:[6,7,8], read:"You have insight but no resourced bets. This is pilot purgatory: the strategy exists on paper but not in the budget. Concentrate resources on a few sequenced moves."},
    Adapt:  {q:[9], read:"You have a plan but no learning system. Model capability moves faster than annual planning — without a sensing-and-adapting loop, today's strategy is stale within two quarters."}
  };

  var Q = [
    {phase:"Orient", label:["Disruption","Thesis"],
     text:"How clear is our thesis for how AI reshapes the economics of our industry?",
     measures:"Whether we have a specific, testable view of what gets commoditized and where value migrates.",
     a:{1:"No real point of view. We talk about AI in terms of tools, not economics.",3:"A general sense that AI matters, but no specific, testable thesis on where value moves.",5:"A crisp, falsifiable thesis on what AI commoditizes and where value migrates — and we use it."},
     lens:"Every technology shift redistributes profit by changing what is scarce. AI collapses the cost of cognition — reading, writing, analysis, coding — so advantage migrates to whatever becomes the new bottleneck. A real thesis names, for your industry specifically, what gets commoditized and where the value moves.",
     erodes:"Advantages built on cognitive labor being expensive — drafting, research, first-pass analysis.",
     endures:"Whatever becomes the new constraint once cognition is cheap: judgment, trust, proprietary inputs.",
     example:"'AI will help us' is not a thesis. 'AI makes underwriting labor cheap, so advantage shifts to our proprietary default data' is — and you can act on it.",
     bands:{low:"You're operating without a point of view on how AI changes your industry's economics, so every downstream AI choice is a guess.",mid:"You sense AI matters but lack a specific, testable thesis. That vagueness makes it hard to prioritize investment or defend it to the board.",high:"You hold a crisp, falsifiable thesis on what AI commoditizes and where value migrates — the foundation every other choice builds on."},
     move:"Write one falsifiable sentence — 'AI collapses the cost of X, shifting advantage from Y to Z' — and name the evidence that would prove it wrong."},

    {phase:"Orient", label:["Moat","Impact"],
     text:"Do we know whether AI erodes or amplifies our sources of competitive advantage?",
     measures:"Whether each moat has been stress-tested against AI, not just discussed in passing.",
     a:{1:"We've never assessed whether AI strengthens or erodes our advantages.",3:"We've discussed it informally, but haven't stress-tested each moat or timed the erosion.",5:"Every moat stress-tested against AI; we know which amplify, which erode, and by when."},
     lens:"AI dissolves some moats and compounds others. Advantages built on knowing how to do something — information asymmetry, generic expertise, process documentation, labor scale — erode as AI democratizes capability. Advantages built on hard-to-copy assets — proprietary data, embedded workflow, trust, regulation — grow stronger.",
     erodes:"Information asymmetry, basic software features, generic knowledge work, process docs, labor arbitrage.",
     endures:"Proprietary data, embedded workflows, switching costs, trust in high-stakes contexts, regulatory position.",
     example:"The acid test: if every competitor had your AI model tomorrow, what advantage would remain? Whatever survives that question is your real moat.",
     bands:{low:"You haven't stress-tested your advantages against AI, so some may be eroding on a clock you can't see.",mid:"You've discussed AI's effect informally but haven't classified each moat as amplified or eroding, or put a horizon on the ones at risk.",high:"You've stress-tested every moat, know which AI amplifies versus erodes, and have time horizons on the vulnerable ones."},
     move:"Classify each advantage into eroding-fast / under-pressure / defensible-if-strengthened / increasingly-valuable, and put a time-to-erosion on the top risks."},

    {phase:"Orient", label:["Customer","Shift"],
     text:"Do we understand how AI is shifting what our customers expect and value?",
     measures:"Whether we're tracking where the customer's bar is heading, not just where it is today.",
     a:{1:"We assume customer expectations are stable and aren't tracking AI-driven shifts.",3:"We sense expectations are rising but haven't mapped table stakes vs. differentiators.",5:"We've mapped where expectations are heading and invest against the shift, not today's bar."},
     lens:"Your competitors set the pace of customer expectations, not you. As AI makes instant, personalized, always-on service cheap, yesterday's delighter becomes table stakes. At the same time, in high-stakes contexts, human trust and accountability become more valued, not less.",
     erodes:"Speed, availability, and basic personalization as sources of differentiation — soon expected of everyone.",
     endures:"Trust, curation, and accountability where the stakes of being wrong are high.",
     example:"When a rival answers in seconds at 2am, a two-day human turnaround stops reading as 'thorough' and starts reading as 'slow.'",
     bands:{low:"You're optimizing for today's customer while the bar moves under you — and expectation resets tend to arrive suddenly.",mid:"You sense expectations are rising but haven't mapped what is becoming table stakes versus what stays a real differentiator.",high:"You've mapped where expectations are heading and invest against the shift, including where human trust becomes more valuable."},
     move:"Write the 2027 customer complaint an AI-native rival would make possible — then decide what would have to be true for it to be impossible."},

    {phase:"Assess", label:["Proprietary","Assets"],
     text:"Have we identified the proprietary assets that become more valuable in an AI world?",
     measures:"Whether we can name defensible crown jewels — not just say 'we have data'.",
     a:{1:"We haven't identified which assets gain value with AI. 'We have data' is as far as it goes.",3:"We know we hold valuable assets but haven't tested their uniqueness or AI-relevance.",5:"Assets inventoried, crown jewels identified — and we can say why a startup couldn't copy them."},
     lens:"When models are a commodity, advantage accrues to whoever owns what the model needs and can't download: proprietary, outcome-labeled data; embedded workflows; distribution; trust; regulatory position. The single most durable AI-era moat is proprietary data plus an embedded workflow — data no one else has, wired into a process customers already rely on.",
     erodes:"Generic data, off-the-shelf tooling, and 'we have lots of data' claims that aren't unique or labeled.",
     endures:"Proprietary, longitudinal, outcome-labeled data; workflow integration; privileged distribution.",
     example:"Two firms run the same model; one has ten years of outcome-labeled data wired into the customer's daily workflow, the other has a chatbot. Same AI, opposite defensibility.",
     bands:{low:"You haven't identified which assets gain value with AI. 'We have data' is not yet a moat — uniqueness, labeling, and legal usability are what matter.",mid:"You know you hold valuable assets but haven't rigorously tested their uniqueness or why a funded startup couldn't replicate them.",high:"You've inventoried your assets, named defensible crown jewels, and can articulate why they can't be bought off the shelf."},
     move:"For each candidate asset, answer 'why couldn't a two-person startup with the same model replicate this in a year?' No hard answer means it's a to-do, not a moat."},

    {phase:"Assess", label:["Value","Pools"],
     text:"Have we mapped and sized where the AI value actually is?",
     measures:"Whether opportunities are sized across cost, growth, and new models — or skewed to cost.",
     a:{1:"We haven't sized the opportunity. Interest is scattered and mostly about cost.",3:"We have a list of ideas but little sizing, and a heavy skew toward cost over growth.",5:"Value pools mapped and sized across cost, growth, and new models — biggest prizes prioritized."},
     lens:"AI value sits in three buckets: cost (efficiency — real, but quickly competed away), growth (better products, personalization, retention), and new models (offerings impossible before AI). The durable prizes usually live in growth and new models; a cost-only program shrinks efficiently while rivals grow.",
     erodes:"Cost-only plays — everyone gets the same efficiency from the same tools, so it rarely compounds.",
     endures:"Growth and new-model plays anchored to a proprietary asset that competitors can't replicate.",
     example:"Deflecting support tickets is a cost play any rival copies. Turning your proprietary data into a new AI-enabled product is one that compounds.",
     bands:{low:"You haven't sized the opportunity, and interest skews to cost — so the biggest, most defensible prizes are likely invisible.",mid:"You have a list of ideas but little sizing and a heavy cost tilt, which makes it hard to prioritize the prizes that compound.",high:"You've sized value across cost, growth, and new models and prioritized the biggest, most defensible prizes."},
     move:"Force at least three growth or new-model ideas tied to a crown-jewel asset, and size the top three by prize and feasibility."},

    {phase:"Assess", label:["Capability"],
     text:"Are we actually capable of capturing the opportunity — from pilot to production?",
     measures:"Whether data, talent, operating model, and adoption can carry an idea to scale.",
     a:{1:"Data, talent, operating model, and adoption aren't ready. Pilots stall.",3:"Pockets of capability, but a real gap between pilot and production.",5:"We move ideas from pilot to scaled production — data, talent, model, and adoption are in place."},
     lens:"Strategy is bounded by execution. The gap between a promising pilot and a scaled, production capability — data, talent, operating model, adoption — swallows more AI ambition than any competitor does. Advantage compounds only if you can move from pilot to production.",
     erodes:"Pilot-stage novelty that never scales — impressive demos with no operational change behind them.",
     endures:"An execution engine — data pipelines, talent, workflow redesign, adoption — that turns ideas into scaled reality.",
     example:"A brilliant model the frontline won't use delivers nothing. Adoption and workflow redesign usually bind harder than the technology itself.",
     bands:{low:"Data, talent, operating model, or adoption aren't ready, and pilots stall before they scale.",mid:"You have pockets of capability but a real, unclosed gap between pilot and production.",high:"You can take ideas from pilot to scaled production — the execution engine that turns strategy into advantage."},
     move:"Run a pilot-to-production pre-mortem on your flagship use case and convert the top three failure causes into pre-conditions to fix now."},

    {phase:"Commit", label:["Build / Buy","/ Partner"],
     text:"Do we have discipline about where we adopt, build, or partner?",
     measures:"Whether make/buy/partner calls follow a consistent logic tied to differentiation.",
     a:{1:"Ad hoc calls — we sometimes build what we should simply buy.",3:"We decide case by case, without a consistent framework tied to differentiation.",5:"Clear discipline: adopt commodity, partner for speed, build only where an asset makes it defensible."},
     lens:"Discipline is the whole game: adopt commodity capability (most things), partner for speed or shared risk, and build only where a proprietary asset makes it defensible. Almost no one should build foundation models; the advantage is what you build on top of them with your own data and workflow.",
     erodes:"Building undifferentiated capability for prestige — burning scarce talent on what you could have bought.",
     endures:"Building narrowly and deeply where you own the asset that makes it hard to copy.",
     example:"Building a generic chatbot is AI theater; building a model on data only you own is a moat. Spend scarce talent only on the latter.",
     bands:{low:"Sourcing is ad hoc — you risk building what you should buy and burning scarce talent on undifferentiated work.",mid:"You decide case by case without a consistent framework tied to differentiation.",high:"You have clear discipline: adopt, partner, or build based on whether a proprietary asset makes building defensible."},
     move:"Route each initiative through one tree — differentiator? own the asset? can we maintain it? — and estimate the loaded cost of every 'build.'"},

    {phase:"Commit", label:["Portfolio &","Sequencing"],
     text:"Do we manage a balanced, sequenced portfolio of AI moves?",
     measures:"Whether initiatives are balanced across no-regret / big bet / option and deliberately ordered.",
     a:{1:"A scatter of disconnected pilots with no sequencing logic.",3:"Initiatives underway, but not balanced or deliberately sequenced.",5:"A balanced portfolio (no-regret / big bet / option) with a sequenced roadmap and a clear first move."},
     lens:"Under uncertainty you run a portfolio, not a single plan: no-regret moves (valuable in any future), big bets (few, well-resourced, tied to your right to win), and options (cheap rights to scale later). Then you sequence — early wins that build the data, skills, and credibility to unlock the big bet.",
     erodes:"A scatter of disconnected pilots — motion without compounding, and nothing that unlocks the next move.",
     endures:"A sequenced chain where each move builds the asset or capability that makes the next one possible.",
     example:"A dozen disconnected pilots isn't a strategy. One sequenced chain where each move unlocks the next is.",
     bands:{low:"A scatter of disconnected pilots with no sequencing logic — motion without compounding.",mid:"Initiatives are underway but not balanced across move-types or deliberately sequenced.",high:"You run a balanced, sequenced portfolio with a clear first domino that unlocks the bigger bets."},
     move:"Sort initiatives into no-regret / big bet / option, resource the bets like bets, and name the first domino that unlocks the rest."},

    {phase:"Commit", label:["Risk &","Governance"],
     text:"Have we defined our AI risk appetite and how we govern it?",
     measures:"Whether we have explicit bright lines and decision rights that let us deploy with confidence.",
     a:{1:"No defined risk appetite or governance — we're either reckless or frozen.",3:"Some policies, but no explicit risk appetite, bright lines, or clear decision rights.",5:"Defined appetite, clear bright lines, and lightweight governance that lets us deploy with confidence."},
     lens:"The goal is not zero risk — that means doing nothing. It's a deliberate risk appetite. In high-stakes and regulated contexts, governance is itself a moat: it slows entrants and reassures buyers, letting you deploy where rivals hesitate. Bright lines where they matter, speed everywhere else.",
     erodes:"Both extremes — reckless deployment that invites an incident, and paralysis that cedes the market.",
     endures:"Governance capability and regulatory trust that become a barrier to entry in risk-sensitive markets.",
     example:"A single AI incident can set a program back years. Clear red lines and decision rights are what let you move fast safely.",
     bands:{low:"No defined risk appetite or governance — you're either frozen or exposed.",mid:"Some policies, but no explicit appetite, bright lines, or clear decision rights.",high:"A defined appetite, clear bright lines, and lightweight governance that lets you deploy with confidence."},
     move:"Draw three to five 'we will never use AI to…' lines (the front-page test) and name who decides, who reviews, and what escalates."},

    {phase:"Adapt", label:["Sense &","Adapt"],
     text:"Do we have a living system to sense change, measure impact, and re-strategize?",
     measures:"Whether the strategy is a loop — metrics, cadence, triggers, and an owner — or a static plan.",
     a:{1:"Our strategy, if we have one, is static — no metrics, cadence, or triggers.",3:"We review occasionally, but without defined metrics, triggers, or an owner.",5:"A living system: leading/lagging metrics, a fixed cadence, change-our-mind triggers, a named owner."},
     lens:"Model capability improves faster than any annual planning cycle, so durable advantage comes from adaptive systems, not static plans. The AI-era flywheel: usage produces proprietary data, which improves models, which deepens adoption, which produces more usage. A sensing loop — metrics, triggers, and an owner — is what keeps you ahead.",
     erodes:"Static, set-once strategies and one-off pilots — stale within two quarters as the frontier moves.",
     endures:"Compounding flywheels: data network effects, model-improvement loops, and operational learning.",
     example:"The winners don't 'have AI'; they run a learning system that competitors can't catch — data, model, and operational-learning loops that compound.",
     bands:{low:"Your strategy is static — no metrics, cadence, or triggers — so it will be stale within two quarters.",mid:"You review occasionally but without defined metrics, change-our-mind triggers, or a named owner.",high:"You run a living system — leading/lagging metrics, a fixed cadence, pre-committed triggers, and an owner — the flywheel that compounds advantage."},
     move:"Define one leading and one lagging metric per big bet, pre-commit the triggers that would change your mind, and name the loop's owner."}
  ];

  var BANDS = [
    {min:0,   name:"Exposed",   d:"You're moving without a strategy. The risk isn't making a wrong bet — it's being outmaneuvered while you deliberate."},
    {min:2.0, name:"Developing",d:"Real intent, foundational gaps. The groundwork isn't yet in place to convert ambition into durable advantage."},
    {min:3.0, name:"Advancing", d:"Genuine progress with specific gaps. You're ahead of most; the work now is sharpening the thesis and sequencing the bets."},
    {min:4.0, name:"Leading",   d:"Ahead of the field. The priority shifts from catching up to compounding the lead and defending it."}
  ];

